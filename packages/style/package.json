{
  "name": "@sumisonic/bezier-kit-style",
  "version": "0.2.0",
  "description": "Style-aware bezier path interpolation and splitting (color, gradient, stroke)",
  "license": "MIT",
  "author": "sumisonic",
  "repository": {
    "type": "git",
    "url": "https://github.com/sumisonic/bezier-kit.git",
    "directory": "packages/style"
  },
  "homepage": "https://github.com/sumisonic/bezier-kit#readme",
  "bugs": {
    "url": "https://github.com/sumisonic/bezier-kit/issues"
  },
  "keywords": [
    "bezier",
    "gradient",
    "color-interpolation",
    "stroke",
    "morph",
    "morphing",
    "2d",
    "typescript",
    "functional"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run --passWithNoTests",
    "bench": "vitest bench --run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@sumisonic/bezier-kit-core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
